# Cloudflare Pages cache + security headers
# Static export ignores next.config headers(), so they live here instead.

# Hashed Next.js chunks — safe to cache forever (filename changes on every build)
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts and icons in /public
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.ico
  Cache-Control: public, max-age=86400

# Static public images — cache 1 year (content-addressed via git deploy hash)
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.avif
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=86400

# Admin, account, checkout, auth, cart — private/utility pages: never index, never cache
/admin/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

/account/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

/checkout/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

/login/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

/signup/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

/cart/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

# HTML pages — short TTL + stale-while-revalidate for fast CDN delivery + fresh content
/*
  Cache-Control: public, max-age=60, stale-while-revalidate=300
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  # HSTS: 1-year, subdomains, preload-eligible
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # XSS protection for legacy browsers
  X-XSS-Protection: 1; mode=block
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://checkout.razorpay.com https://cdn.razorpay.com https://www.googletagmanager.com https://connect.facebook.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://res.cloudinary.com https://razorpay.com https://*.razorpay.com https://cdn.razorpay.com https://images.unsplash.com https://www.google-analytics.com https://www.facebook.com https://www.googletagmanager.com https://*.cdninstagram.com https://*.fbcdn.net; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://backend-production-73aa.up.railway.app https://api.kalokea.in https://api.razorpay.com https://lumberjack.razorpay.com https://www.google-analytics.com https://region1.google-analytics.com https://www.facebook.com https://connect.facebook.net https://res.cloudinary.com https://images.unsplash.com; frame-src https://*.razorpay.com https://api.razorpay.com https://cdn.razorpay.com; object-src 'none'; base-uri 'self'; form-action 'self' https://*.razorpay.com; frame-ancestors 'none'; upgrade-insecure-requests
