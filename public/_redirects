# ── Canonical URL consolidation ──────────────────────────────────────────────
# These duplicate pages were removed; Google canonical is the -policy variant.
/privacy          /privacy-policy/    301
/shipping         /shipping-policy/   301
/returns-policy   /refund-policy/     301
/refund           /refund-policy/     301

# Product detail pages are now statically prerendered at /product/<slug>/
# (app/product/[slug]). The old /product?slug= reverse-redirect has been removed
# because it would hijack the real static pages.

# Bare /product index → shop listing.
/product  /shop/  301

# Fallback for product pages NOT yet in the static build (new products added
# after the last deploy). Static files take priority — this rewrite only fires
# when /product/<slug>/index.html does not exist yet. The client JS at /product/
# reads the slug from window.location.pathname and fetches the product live.
/product/*  /product/  200

# --- Legacy WooCommerce URL 301s ---------------------------------------------
# WooCommerce product URLs were already /product/<slug>/ — those map 1:1 to the
# new static pages, so no redirect is needed for them.
/product-category/tops          /shop/tops/           301
/product-category/dresses       /shop/dresses/        301
/product-category/bottoms       /shop/bottoms/        301
/product-category/shoes         /shop/shoes/          301
/product-category/bags          /shop/bags/           301
/product-category/accessories   /shop/accessories/    301
/product-category/sale          /shop/sale/           301
/product-category/:cat          /shop/                301
/product-category/*             /shop/                301
/product-tag/*                  /shop/                301
/shop/page/*                    /shop/                301
/my-account                     /account/             301
/my-account/*                   /account/             301

# WordPress-specific URLs
/wp-login.php                   /login/               301
/wp-admin                       /admin/               301
/wp-admin/*                     /admin/               301
/?s=:q                          /shop/                301
/feed                           /                     301
/feed/*                         /                     301
/?p=:id                         /shop/                301
/?page_id=:id                   /                     301


